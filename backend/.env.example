# MedSedule backend environment variables — copy to .env
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/medsedule

# JWT
JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Gmail SMTP (use Gmail App Password, NOT your real password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM_NAME=MedSedule

# Frontend URL (used in CORS + email links)
CLIENT_URL=http://localhost:5173
